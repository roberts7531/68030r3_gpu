`pragma protect end_protected
module Integer_Division_Top (
  clk,
  rstn,
  dividend,
  divisor,
  remainder,
  quotient
)
;
input clk;
input rstn;
input [20:0] dividend;
input [10:0] divisor;
output [10:0] remainder;
output [20:0] quotient;
wire VCC;
wire GND;
  \(integer_division)/(Integer_Division_Top)(N=21,M=11,LATENCY=10)  integer_division_inst (
    .clk(clk),
    .rstn(rstn),
    .dividend(dividend[20:0]),
    .divisor(divisor[10:0]),
    .quotient(quotient[20:0]),
    .remainder(remainder[10:0])
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
  GSR GSR (
    .GSRI(VCC) 
);
endmodule /* Integer_Division_Top */
